# Application
NODE_ENV=development
PORT=8000
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=nmsl_healthcare
DATABASE_SYNC=true

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_characters_here
JWT_EXPIRATION=7d

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string
AZURE_STORAGE_CONTAINER=nmsl-medical-files

# Email (Azure Communication Services)
# Get connection string from: Azure Portal → Communication Services → Keys
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://your-acs.communication.azure.com/;accesskey=your-key
EMAIL_FROM=DoNotReply@your-verified-domain.com

# Redis (Azure Cache for Redis)
# Get from: Azure Portal → Azure Cache for Redis → Access keys
REDIS_HOST=your-redis-name.redis.cache.windows.net
REDIS_PORT=6380
REDIS_PASSWORD=your-redis-primary-key
REDIS_TTL=1800
REDIS_TLS=true

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
