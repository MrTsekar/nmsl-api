{
  "info": {
    "name": "NMSL Healthcare API",
    "_postman_id": "nmsl-api-collection",
    "description": "Complete Postman collection for the NMSL Healthcare NestJS API.\n\nBase URL: http://localhost:4000/api/v1\n\nWorkflow:\n1. Run 'Auth / Sign In' → copy the token\n2. Set the collection variable `token` to the copied value\n3. All protected routes use {{baseUrl}} and Bearer {{token}} automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api/v1", "type": "string" },
    { "key": "token",   "value": "",                             "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign In (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/sign-in",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@nmsl.app\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@nmsl.app\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<reset-token-from-email>\",\n  \"password\": \"NewPassword123!\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/me",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"phone\": \"+2348099999999\",\n  \"address\": \"5 New Address\",\n  \"gender\": \"male\"\n}"
            }
          }
        },
        {
          "name": "Change My Password",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/me/password",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"NewPassword456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin — KPIs",
      "item": [
        {
          "name": "Get KPIs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/kpis",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        }
      ]
    },
    {
      "name": "Admin — Doctors",
      "item": [
        {
          "name": "Get All Doctors",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/doctors?location=Abuja&specialty=Cardiology",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "doctors"],
              "query": [
                { "key": "location", "value": "Abuja", "disabled": true },
                { "key": "specialty", "value": "Cardiology", "disabled": true }
              ]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        },
        {
          "name": "Create Doctor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/doctors",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Sarah Chen\",\n  \"email\": \"sarah.chen@nmsl.com\",\n  \"password\": \"Doctor123!\",\n  \"phone\": \"+2348012345678\",\n  \"location\": \"Abuja\",\n  \"state\": \"FCT\",\n  \"specialty\": \"General Practice\",\n  \"yearsOfExperience\": 8\n}"
            }
          }
        }
      ]
    },
