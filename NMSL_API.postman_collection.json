          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/admins",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Admin\",\n  \"email\": \"john.admin@nmsl.com\",\n  \"password\": \"Admin123!\",\n  \"phone\": \"+2348011112222\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Create Appointment Officer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/admins",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mary Officer\",\n  \"email\": \"mary.officer@nmsl.com\",\n  \"password\": \"Officer123!\",\n  \"phone\": \"+2348033334444\",\n  \"role\": \"appointment_officer\"\n}"
            }
          }
        },
        {
          "name": "Toggle Admin Status",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/admin/admins/:id/toggle-status",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "admins", ":id", "toggle-status"],
              "variable": [{ "key": "id", "value": "<admin-id>" }]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        },
        {
          "name": "Change Admin Password",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/admin/admins/:id/password",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "admins", ":id", "password"],
              "variable": [{ "key": "id", "value": "<admin-id>" }]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"NewAdminPass1!\"\n}"
            }
          }
        },
        {
          "name": "Delete Admin",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/admin/admins/:id",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "admins", ":id"],
              "variable": [{ "key": "id", "value": "<admin-id>" }]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        }
      ]
    },
